{
  "name": "chromiumfish_mcp",
  "version": "0.4.0",
  "description": "A secure, session-aware MCP server for ChromiumFish.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "bin": {
    "chromiumfish_mcp": "./dist/index.js",
    "chromiumfish-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chromiumfish",
    "browser",
    "playwright",
    "automation"
  ],
  "author": "LowOrbitLab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LowOrbitLab/chromiumfish_mcp.git"
  },
  "bugs": {
    "url": "https://github.com/LowOrbitLab/chromiumfish_mcp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chromiumfish": "^0.2.3",
    "playwright-core": "^1.61.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "typescript": "^5.9.3"
  }
}
